    "sort:essence:write": "node scripts/sortCannithPhase1.mjs --write",
    "normalize:essence": "node scripts/normalizeCannithPhase1.mjs",
    "normalize:essence:write": "node scripts/normalizeCannithPhase1.mjs --write"
  },
  "dependencies": {
    "@dr.pogodin/react-helmet": "^3.1.1",
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.11.2",
    "bootstrap": "^5.3.8",
    "camelcase": "^9.0.0",
    "fast-xml-parser": "^5.5.11",
    "idb-keyval": "^6.2.2",
    "kebab-case": "^2.0.2",
    "luxon": "^3.7.2",
    "lz-string": "^1.5.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.0",
