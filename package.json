{
  "name": "yourddo-react",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "go run ./tools/cannithSplit/main.go ./tools/cannithSplit/transform.go ./tools/cannithSplit/types.go ./tools/cannithSplit/indexes.go src/data/essenceCrafting/essenceEnhancements.phase1.json src/data/essenceCrafting/runtime && yarn items:data && go run ./tools/dataSpider/indexer/main.go",
    "items:data": "yarn items:data:armor && yarn items:data:augment && yarn items:data:clothing && yarn items:data:collar && yarn items:data:filigree && yarn items:data:jewelry && yarn items:data:quiver && yarn items:data:runeArms && yarn items:data:shields && yarn items:data:weapons && yarn update:fountain",
    "items:data:armor": "go run ./tools/dataSpider Armor",
    "items:data:augment": "go run ./tools/dataSpider Augment",
    "items:data:clothing": "go run ./tools/dataSpider Clothing",
    "items:data:collar": "go run ./tools/dataSpider Collar",
    "items:data:filigree": "go run ./tools/dataSpider Filigrees",
    "items:data:jewelry": "go run ./tools/dataSpider Jewelry",
    "items:data:quiver": "go run ./tools/dataSpider Quiver",
    "items:data:runeArms": "go run ./tools/dataSpider \"Rune Arm\"",
    "items:data:shields": "go run ./tools/dataSpider Shield",
    "items:data:weapons": "go run ./tools/dataSpider Simple && go run ./tools/dataSpider Martial && go run ./tools/dataSpider Exotic && go run ./tools/dataSpider Throwing",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "sort:essence": "node scripts/sortCannithPhase1.mjs",
    "sort:essence:write": "node scripts/sortCannithPhase1.mjs --write",
    "normalize:essence": "node scripts/normalizeCannithPhase1.mjs",
    "normalize:essence:write": "node scripts/normalizeCannithPhase1.mjs --write",
    "update:fountain": "go run ./tools/fountainUpdate/main.go"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.12.0",
    "bootstrap": "^5.3.8",
    "camelcase": "^9.0.0",
    "fast-xml-parser": "^5.8.0",
    "idb-keyval": "^6.2.4",
    "kebab-case": "^2.0.2",
    "luxon": "^3.7.2",
    "lz-string": "^1.5.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.16.0",
    "simple-xml-to-json": "^1.2.7",
    "sitemap": "^9.0.1",
    "title-case": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.6",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bootstrap": "^5.2.10",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-zod": "^4.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.7"
  },
  "packageManager": "yarn@4.14.1",
  "resolutions": {
    "glob/minimatch": "9.0.7"
  }
}
