{
  "name": "yourddo-react",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "go run ./tools/cannithSplit/main.go ./tools/cannithSplit/transform.go ./tools/cannithSplit/types.go ./tools/cannithSplit/indexes.go src/data/essenceCrafting/essenceEnhancements.phase1.json src/data/essenceCrafting/runtime && yarn items:data && go run ./tools/dataSpider/indexer/main.go",
    "items:data": "yarn items:data:armor && yarn items:data:augment && yarn items:data:clothing && yarn items:data:collar && yarn items:data:jewelry && yarn items:data:quiver && yarn items:data:runeArms && yarn items:data:shields && yarn items:data:weapons",
    "items:data:armor": "go run ./tools/dataSpider Armor",
    "items:data:augment": "go run ./tools/dataSpider Augment",
    "items:data:clothing": "go run ./tools/dataSpider Clothing",
    "items:data:collar": "go run ./tools/dataSpider Collar",
    "items:data:jewelry": "go run ./tools/dataSpider Jewelry",
    "items:data:quiver": "go run ./tools/dataSpider Quiver",
    "items:data:runeArms": "go run ./tools/dataSpider \"Rune Arm\"",
    "items:data:shields": "go run ./tools/dataSpider Shield",
    "items:data:weapons": "go run ./tools/dataSpider Simple && go run ./tools/dataSpider Martial && go run ./tools/dataSpider Exotic && go run ./tools/dataSpider Throwing",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "sort:essence": "node scripts/sortCannithPhase1.mjs",
    "sort:essence:write": "node scripts/sortCannithPhase1.mjs --write",
    "normalize:essence": "node scripts/normalizeCannithPhase1.mjs",
    "normalize:essence:write": "node scripts/normalizeCannithPhase1.mjs --write"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.11.2",
    "bootstrap": "^5.3.8",
    "camelcase": "^9.0.0",
    "fast-xml-parser": "^5.5.10",
    "idb-keyval": "^6.2.2",
    "kebab-case": "^2.0.2",
    "luxon": "^3.7.2",
    "lz-string": "^1.5.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.0",
    "simple-xml-to-json": "^1.2.5",
    "sitemap": "^9.0.1",
    "title-case": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bootstrap": "^5.2.10",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vite-plugin-compression": "^0.5.1"
  },
  "packageManager": "yarn@4.13.0"
}
